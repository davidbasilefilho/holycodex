{
  "name": "holycodex-workspace",
  "version": "0.9.0",
  "private": true,
  "description": "Lean Codex-only agent toolkit for ChatGPT Plus",
  "keywords": [
    "agents",
    "chatgpt",
    "codex",
    "mcp"
  ],
  "homepage": "https://github.com/davidbasilefilho/holycodex#readme",
  "bugs": {
    "url": "https://github.com/davidbasilefilho/holycodex/issues"
  },
  "license": "SUL-1.0",
  "author": "David Basile Filho",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidbasilefilho/holycodex.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "check": "vp check --fix",
    "test": "vp run build && vp test",
    "build": "vp build --config vite.config.ts && vp build --config packages/cli/vite.config.ts",
    "version:check": "bun scripts/version.mjs check",
    "version:patch": "bun scripts/version.mjs patch",
    "version:minor": "bun scripts/version.mjs minor",
    "version:set": "bun scripts/version.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "bun-types": "1.3.12",
    "typescript": "^6.0.0",
    "vite": "^7.0.0",
    "vite-plus": "^0.2.5",
    "vitest": "^4.0.0",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.14"
}
