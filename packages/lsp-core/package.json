{
  "name": "@holycodex/lsp-core",
  "version": "0.7.1",
  "private": true,
  "description": "HolyCodex Language Server Protocol engine and tool definitions.",
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./tools": {
      "types": "./src/tools.ts",
      "import": "./src/tools.ts"
    },
    "./request-context": {
      "types": "./src/request-context.ts",
      "import": "./src/request-context.ts"
    },
    "./missing-dependency-result": {
      "types": "./src/missing-dependency-result.ts",
      "import": "./src/missing-dependency-result.ts"
    },
    "./mcp": {
      "types": "./src/mcp.ts",
      "import": "./src/mcp.ts"
    },
    "./lsp/*": {
      "types": "./src/lsp/*.ts",
      "import": "./src/lsp/*.ts"
    }
  },
  "scripts": {
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "test": "bun test src/*.test.ts src/**/*.test.ts"
  },
  "dependencies": {
    "@holycodex/mcp-stdio-core": "workspace:*"
  }
}
