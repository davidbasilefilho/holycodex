{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/omo.schema.json",
  "title": "Omo Configuration",
  "description": "Configuration schema for the omo.json / omo.jsonc harness-neutral config surface",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "categories": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "fallback_models": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "model": {
                      "type": "string"
                    },
                    "variant": {
                      "type": "string"
                    },
                    "reasoningEffort": {
                      "type": "string",
                      "enum": [
                        "none",
                        "minimal",
                        "low",
                        "medium",
                        "high",
                        "xhigh",
                        "max"
                      ]
                    },
                    "temperature": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 2
                    },
                    "top_p": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1
                    },
                    "maxTokens": {
                      "type": "number"
                    },
                    "thinking": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "enum": [
                            "enabled",
                            "disabled"
                          ]
                        },
                        "budgetTokens": {
                          "type": "number"
                        }
                      },
                      "required": [
                        "type"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "required": [
                    "model"
                  ],
                  "additionalProperties": false
                }
              },
              {
                "type": "array",
                "items": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "model": {
                          "type": "string"
                        },
                        "variant": {
                          "type": "string"
                        },
                        "reasoningEffort": {
                          "type": "string",
                          "enum": [
                            "none",
                            "minimal",
                            "low",
                            "medium",
                            "high",
                            "xhigh",
                            "max"
                          ]
                        },
                        "temperature": {
                          "type": "number",
                          "minimum": 0,
                          "maximum": 2
                        },
                        "top_p": {
                          "type": "number",
                          "minimum": 0,
                          "maximum": 1
                        },
                        "maxTokens": {
                          "type": "number"
                        },
                        "thinking": {
                          "type": "object",
                          "properties": {
                            "type": {
                              "type": "string",
                              "enum": [
                                "enabled",
                                "disabled"
                              ]
                            },
                            "budgetTokens": {
                              "type": "number"
                            }
                          },
                          "required": [
                            "type"
                          ],
                          "additionalProperties": false
                        }
                      },
                      "required": [
                        "model"
                      ],
                      "additionalProperties": false
                    }
                  ]
                }
              }
            ]
          },
          "variant": {
            "type": "string"
          },
          "temperature": {
            "type": "number",
            "minimum": 0,
            "maximum": 2
          },
          "top_p": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "maxTokens": {
            "type": "number"
          },
          "thinking": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "enabled",
                  "disabled"
                ]
              },
              "budgetTokens": {
                "type": "number"
              }
            },
            "required": [
              "type"
            ],
            "additionalProperties": false
          },
          "reasoningEffort": {
            "type": "string",
            "enum": [
              "none",
              "minimal",
              "low",
              "medium",
              "high",
              "xhigh",
              "max"
            ]
          },
          "textVerbosity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "tools": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "type": "boolean"
            }
          },
          "prompt_append": {
            "type": "string"
          },
          "max_prompt_tokens": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "is_unstable_agent": {
            "type": "boolean"
          },
          "disable": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "agents": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string"
          },
          "prompt": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "models": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "tools": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "type": "boolean"
            }
          },
          "execution_mode": {
            "type": "string",
            "enum": [
              "in-process",
              "process"
            ]
          },
          "background": {
            "type": "boolean"
          },
          "max_depth": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "allowed_subagents": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "temperature": {
            "type": "number",
            "minimum": 0,
            "maximum": 2
          },
          "disable": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "task": {
      "type": "object",
      "properties": {
        "default_execution_mode": {
          "default": "in-process",
          "type": "string",
          "enum": [
            "in-process",
            "process"
          ]
        },
        "default_concurrency": {
          "default": 5,
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "provider_concurrency": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          }
        },
        "model_concurrency": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          }
        },
        "max_depth": {
          "default": 1,
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "residency_max_children": {
          "default": 8,
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "notification": {
          "default": {
            "deliver_as": "followUp"
          },
          "type": "object",
          "properties": {
            "deliver_as": {
              "default": "followUp",
              "type": "string",
              "enum": [
                "followUp",
                "steer"
              ]
            }
          },
          "required": [
            "deliver_as"
          ],
          "additionalProperties": false
        },
        "ttl_ms": {
          "default": 86400000,
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "state_dir": {
          "type": "string"
        },
        "wait": {
          "default": {
            "min_ms": 5000,
            "default_ms": 60000,
            "max_ms": 600000
          },
          "type": "object",
          "properties": {
            "min_ms": {
              "default": 5000,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "default_ms": {
              "default": 60000,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "max_ms": {
              "default": 600000,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            }
          },
          "required": [
            "min_ms",
            "default_ms",
            "max_ms"
          ],
          "additionalProperties": false
        },
        "team": {
          "default": {
            "max_members": 8,
            "max_parallel_members": 4,
            "max_wall_clock_minutes": 120
          },
          "type": "object",
          "properties": {
            "max_members": {
              "default": 8,
              "type": "integer",
              "minimum": 1,
              "maximum": 8
            },
            "max_parallel_members": {
              "default": 4,
              "type": "integer",
              "minimum": 1,
              "maximum": 8
            },
            "max_wall_clock_minutes": {
              "default": 120,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            }
          },
          "required": [
            "max_members",
            "max_parallel_members",
            "max_wall_clock_minutes"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "default_execution_mode",
        "default_concurrency",
        "max_depth",
        "residency_max_children",
        "notification",
        "ttl_ms",
        "wait",
        "team"
      ],
      "additionalProperties": false
    },
    "teams": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "version": {
            "default": 1,
            "type": "number",
            "const": 1
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-z0-9-]+$"
          },
          "description": {
            "type": "string"
          },
          "createdAt": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "leadAgentId": {
            "type": "string"
          },
          "teamAllowedPaths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "sessionPermission": {
            "type": "string"
          },
          "members": {
            "minItems": 1,
            "maxItems": 8,
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^[a-z0-9-]+$"
                    },
                    "cwd": {
                      "type": "string"
                    },
                    "worktreePath": {
                      "type": "string"
                    },
                    "subscriptions": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "backendType": {
                      "default": "in-process",
                      "type": "string",
                      "enum": [
                        "in-process",
                        "tmux"
                      ]
                    },
                    "color": {
                      "type": "string"
                    },
                    "isActive": {
                      "default": true,
                      "type": "boolean"
                    },
                    "kind": {
                      "type": "string",
                      "const": "category"
                    },
                    "category": {
                      "type": "string",
                      "minLength": 1
                    },
                    "prompt": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "required": [
                    "name",
                    "backendType",
                    "isActive",
                    "kind",
                    "category",
                    "prompt"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^[a-z0-9-]+$"
                    },
                    "cwd": {
                      "type": "string"
                    },
                    "worktreePath": {
                      "type": "string"
                    },
                    "subscriptions": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "backendType": {
                      "default": "in-process",
                      "type": "string",
                      "enum": [
                        "in-process",
                        "tmux"
                      ]
                    },
                    "color": {
                      "type": "string"
                    },
                    "isActive": {
                      "default": true,
                      "type": "boolean"
                    },
                    "kind": {
                      "type": "string",
                      "const": "subagent_type"
                    },
                    "subagent_type": {
                      "type": "string",
                      "minLength": 1
                    },
                    "prompt": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "name",
                    "backendType",
                    "isActive",
                    "kind",
                    "subagent_type"
                  ],
                  "additionalProperties": false
                }
              ]
            }
          }
        },
        "required": [
          "version",
          "members"
        ],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}