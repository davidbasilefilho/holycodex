    "codex-luna": { "kind": "codex", "model": "gpt-5.6-luna", "effort": "high", "sandbox": "danger-full-access", "networkAccess": true, "approvalPolicy": "never", "command": ["codex", "-c", "model_provider=quotio", "-c", "model_providers.quotio.name=Quotio", "-c", "model_providers.quotio.base_url=https://quotio.mengmota.com/v1", "-c", "model_providers.quotio.env_key=QUOTIO_API_KEY", "-c", "model_providers.quotio.wire_api=responses", "-c", "model_providers.quotio.requires_openai_auth=false", "app-server", "--stdio"] },
